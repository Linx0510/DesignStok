<%- include('../partials/header') %>

<div class="admin-container">
    <div class="admin-sidebar">
        <div class="admin-nav">
            <a href="/admin" class="admin-nav-link <%= path === '/admin' ? 'active' : '' %>">
                <i class="fas fa-dashboard"></i> Дашборд
            </a>
            <a href="/admin/moderation" class="admin-nav-link <%= path === '/admin/moderation' ? 'active' : '' %>">
                <i class="fas fa-check-circle"></i> Модерация
                <% if (stats.works.pending > 0) { %>
                    <span class="badge"><%= stats.works.pending %></span>
                <% } %>
            </a>
            <a href="/admin/complaints" class="admin-nav-link <%= path === '/admin/complaints' ? 'active' : '' %>">
                <i class="fas fa-flag"></i> Жалобы
                <% if (stats.openComplaints > 0) { %>
                    <span class="badge"><%= stats.openComplaints %></span>
                <% } %>
            </a>
            <a href="/admin/users" class="admin-nav-link <%= path === '/admin/users' ? 'active' : '' %>">
                <i class="fas fa-users"></i> Пользователи
            </a>
            <a href="/admin/settings" class="admin-nav-link <%= path === '/admin/settings' ? 'active' : '' %>">
                <i class="fas fa-cog"></i> Настройки
            </a>
        </div>
    </div>
    
    <div class="admin-content">
        <h1>Панель управления</h1>
        
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-info">
                    <h3><%= stats.users %></h3>
                    <p>Всего пользователей</p>
                    <small>+<%= stats.newUsersToday %> сегодня</small>
                </div>
            </div>
            
            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fas fa-image"></i>
                </div>
                <div class="stat-info">
                    <h3><%= stats.works.approved %></h3>
                    <p>Опубликовано работ</p>
                    <small>+<%= stats.worksToday %> сегодня</small>
                </div>
            </div>
            
            <div class="stat-card warning">
                <div class="stat-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-info">
                    <h3><%= stats.works.pending %></h3>
                    <p>Ожидают модерации</p>
                </div>
            </div>
            
            <div class="stat-card danger">
                <div class="stat-icon">
                    <i class="fas fa-flag"></i>
                </div>
                <div class="stat-info">
                    <h3><%= stats.openComplaints %></h3>
                    <p>Открытых жалоб</p>
                </div>
            </div>
        </div>
        
        <div class="admin-grid">
            <div class="admin-card">
                <h2>Последние пользователи</h2>
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Имя</th>
                            <th>Email</th>
                            <th>Роль</th>
                            <th>Дата регистрации</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentUsers.forEach(user => { %>
                            <tr>
                                <td>#<%= user.id %></td>
                                <td><%= user.username %></td>
                                <td><%= user.email %></td>
                                <td>
                                    <span class="badge <%= user.role === 'admin' ? 'badge-primary' : 'badge-secondary' %>">
                                        <%= user.role === 'admin' ? 'Админ' : 'Пользователь' %>
                                    </span>
                                </td>
                                <td><%= new Date(user.created_at).toLocaleDateString('ru-RU') %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
                <a href="/admin/users" class="btn btn-outline btn-sm">Все пользователи</a>
            </div>
            
            <div class="admin-card">
                <h2>Популярные теги</h2>
                <div class="tags-cloud">
                    <% popularTags.forEach(tag => { %>
                        <span class="tag" >
                            #<%= tag.name %> (<%= tag.count %>)
                        </span>
                    <% }) %>
                </div>
            </div>
            
            <div class="admin-card full-width">
                <h2>Активность за последние 7 дней</h2>
                <div class="activity-chart">
                    <% activity.forEach(day => { %>
                        <div class="chart-bar">
                            <div class="bar" ></div>
                            <span class="bar-label"><%= new Date(day.date).toLocaleDateString('ru-RU', { weekday: 'short' }) %></span>
                            <span class="bar-value"><%= day.count %></span>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.admin-container {
    display: flex;
    min-height: calc(100vh - 200px);
}

.admin-sidebar {
    width: 250px;
    background: var(--white);
    padding: 20px;
    border-right: 1px solid var(--light-gray);
}

.admin-nav {
    display: flex;
    flex-direction: column;
    gap: 5px;
}

.admin-nav-link {
    padding: 12px 15px;
    color: var(--dark);
    text-decoration: none;
    border-radius: 5px;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s;
}

.admin-nav-link i {
    width: 20px;
    color: var(--gray);
}

.admin-nav-link:hover {
    background: var(--light);
}

.admin-nav-link.active {
    background: var(--primary);
    color: var(--white);
}

.admin-nav-link.active i {
    color: var(--white);
}

.admin-nav-link .badge {
    margin-left: auto;
    background: var(--primary);
    color: var(--white);
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 12px;
}

.admin-content {
    flex: 1;
    padding: 30px;
}

.admin-content h1 {
    margin-bottom: 30px;
    font-size: 28px;
    color: var(--dark);
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.stat-card {
    background: var(--white);
    padding: 25px;
    border-radius: 10px;
    box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    gap: 20px;
}

.stat-card.warning {
    border-left: 4px solid #ffc107;
}

.stat-card.danger {
    border-left: 4px solid var(--error);
}

.stat-icon {
    width: 60px;
    height: 60px;
    background: var(--light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: var(--primary);
}

.stat-info h3 {
    font-size: 28px;
    margin-bottom: 5px;
    color: var(--dark);
}

.stat-info p {
    color: var(--gray);
    margin-bottom: 5px;
}

.stat-info small {
    color: var(--success);
    font-size: 12px;
}

.admin-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
}

.admin-card {
    background: var(--white);
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 3px 10px rgba(0,0,0,0.1);
}

.admin-card.full-width {
    grid-column: 1 / -1;
}

.admin-card h2 {
    margin-bottom: 20px;
    font-size: 18px;
    color: var(--dark);
}

.admin-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 20px;
}

.admin-table th,
.admin-table td {
    padding: 12px;
    text-align: left;
    border-bottom: 1px solid var(--light-gray);
}

.admin-table th {
    font-weight: 600;
    color: var(--gray);
    font-size: 14px;
}

.tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
}

.activity-chart {
    display: flex;
    align-items: flex-end;
    justify-content: space-around;
    height: 200px;
    padding: 20px 0;
}

.chart-bar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    width: 40px;
}

.bar {
    width: 30px;
    background: var(--primary);
    border-radius: 5px 5px 0 0;
    transition: height 0.3s;
}

.bar-label {
    font-size: 12px;
    color: var(--gray);
}

.bar-value {
    font-size: 12px;
    font-weight: 600;
    color: var(--dark);
}
</style>

<%- include('../partials/footer') %>