<%- include('../partials/header') %>

<div class="admin-container">
    <div class="admin-sidebar">
        <div class="admin-nav">
            <a href="/admin" class="admin-nav-link">Дашборд</a>
            <a href="/admin/moderation" class="admin-nav-link">Модерация</a>
            <a href="/admin/complaints" class="admin-nav-link active">Жалобы</a>
            <a href="/admin/users" class="admin-nav-link">Пользователи</a>
            <a href="/admin/settings" class="admin-nav-link">Настройки</a>
        </div>
    </div>
    
    <div class="admin-content">
        <div class="content-header">
            <h1>Управление жалобами</h1>
            <div class="filter-tabs">
                <a href="/admin/complaints?filter=open" class="filter-tab <%= filter === 'open' ? 'active' : '' %>">
                    Открытые
                    <% if (complaints.filter(c => c.status === 'open').length > 0) { %>
                        <span class="badge"><%= complaints.filter(c => c.status === 'open').length %></span>
                    <% } %>
                </a>
                <a href="/admin/complaints?filter=closed" class="filter-tab <%= filter === 'closed' ? 'active' : '' %>">
                    Закрытые
                </a>
            </div>
        </div>
        
        <% if (complaints && complaints.length > 0) { %>
            <div class="complaints-list">
                <% complaints.forEach(complaint => { %>
                    <div class="complaint-card <%= complaint.status %>" data-id="<%= complaint.id %>">
                        <div class="complaint-header">
                            <div class="complaint-meta">
                                <span class="complaint-id">#<%= complaint.id %></span>
                                <span class="complaint-date">
                                    <i class="fas fa-clock"></i>
                                    <%= new Date(complaint.created_at).toLocaleString('ru-RU') %>
                                </span>
                                <span class="complaint-status status-<%= complaint.status %>">
                                    <%= complaint.status === 'open' ? 'Открыта' : 'Закрыта' %>
                                </span>
                            </div>
                            
                            <% if (complaint.status === 'open') { %>
                                <button class="btn-close-complaint" onclick="closeComplaint(`<%= complaint.id %>`)">
                                    <i class="fas fa-check"></i> Закрыть жалобу
                                </button>
                            <% } %>
                        </div>
                        
                        <div class="complaint-content">
                            <div class="complaint-info">
                                <p><strong>Пожаловался:</strong> 
                                    <a href="/profile/<%= complaint.reporter_user_id %>">
                                        <%= complaint.reporter_name || 'Пользователь удален' %>
                                    </a>
                                </p>
                                <p><strong>На работу:</strong> 
                                    <a href="/works/<%= complaint.work_id %>" target="_blank">
                                        <%= complaint.work_title %>
                                    </a>
                                </p>
                                <p><strong>Автор работы:</strong> 
                                    <a href="/profile/<%= complaint.work_owner_id %>">
                                        <%= complaint.work_owner_name %>
                                    </a>
                                </p>
                                <p><strong>Причина:</strong> <%= complaint.reason %></p>
                            </div>
                            
                            <div class="complaint-work-preview">
                                <img src="<%= complaint.image_path %>" alt="<%= complaint.work_title %>">
                                <div class="complaint-actions">
                                    <a href="/works/<%= complaint.work_id %>" class="btn btn-outline btn-sm" target="_blank">
                                        <i class="fas fa-eye"></i> Просмотр
                                    </a>
                                    <button class="btn btn-danger btn-sm" onclick="showDeleteModal(`<%= complaint.work_id %>`, `<%= complaint.work_title %>`)">
                                        <i class="fas fa-trash"></i> Удалить работу
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
            
            <!-- Пагинация -->
            <% if (totalPages > 1) { %>
                <div class="pagination">
                    <% for(let i = 1; i <= totalPages; i++) { %>
                        <a href="/admin/complaints?page=<%= i %>&filter=<%= filter %>" 
                           class="page <%= currentPage === i ? 'active' : '' %>">
                            <%= i %>
                        </a>
                    <% } %>
                </div>
            <% } %>
            
        <% } else { %>
            <div class="empty-state">
                <i class="fas fa-flag"></i>
                <h3>Нет жалоб</h3>
                <p>Список жалоб пуст</p>
            </div>
        <% } %>
    </div>
</div>

<!-- Модальное окно удаления работы -->
<div id="deleteWorkModal" class="modal">
    <div class="modal-content">
        <span class="close" onclick="hideDeleteModal()">&times;</span>
        <h2>Удаление работы</h2>
        <p>Вы уверены, что хотите удалить работу "<span id="workTitle"></span>"?</p>
        
        <div class="form-group">
            <label for="deleteReason">Причина удаления:</label>
            <textarea id="deleteReason" rows="3" placeholder="Укажите причину удаления..."></textarea>
        </div>
        
        <div class="modal-actions">
            <button class="btn btn-danger" onclick="confirmDelete()">
                <i class="fas fa-trash"></i> Удалить
            </button>
            <button class="btn btn-outline" onclick="hideDeleteModal()">Отмена</button>
        </div>
    </div>
</div>

<script>
let currentWorkId = null;

function closeComplaint(complaintId) {
    if (!confirm('Закрыть жалобу?')) return;
    
    fetch(`/admin/complaints/${complaintId}/close`, {
        method: 'POST',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            const complaint = document.querySelector(`.complaint-card[data-id="${complaintId}"]`);
            complaint.classList.remove('open');
            complaint.classList.add('closed');
            
            const statusBadge = complaint.querySelector('.complaint-status');
            statusBadge.className = 'complaint-status status-closed';
            statusBadge.textContent = 'Закрыта';
            
            const closeBtn = complaint.querySelector('.btn-close-complaint');
            if (closeBtn) closeBtn.remove();
            
            showNotification('Жалоба закрыта', 'success');
        }
    })
    .catch(error => {
        console.error('Ошибка:', error);
        showNotification('Ошибка при закрытии жалобы', 'error');
    });
}

function showDeleteModal(workId, workTitle) {
    currentWorkId = workId;
    document.getElementById('workTitle').textContent = workTitle;
    document.getElementById('deleteWorkModal').style.display = 'block';
}

function hideDeleteModal() {
    currentWorkId = null;
    document.getElementById('deleteWorkModal').style.display = 'none';
    document.getElementById('deleteReason').value = '';
}

async function confirmDelete() {
    const reason = document.getElementById('deleteReason').value.trim();
    
    if (!reason) {
        alert('Укажите причину удаления');
        return;
    }
    
    try {
        const response = await fetch(`/admin/works/${currentWorkId}/delete`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ reason })
        });
        
        const data = await response.json();
        
        if (data.success) {
            // Удаляем все жалобы, связанные с этой работой
            document.querySelectorAll(`.complaint-card`).forEach(card => {
                const workLink = card.querySelector('a[href*="/works/"]');
                if (workLink && workLink.href.includes(`/works/${currentWorkId}`)) {
                    card.remove();
                }
            });
            
            hideDeleteModal();
            showNotification('Работа удалена', 'success');
            
            // Если не осталось жалоб, показываем empty state
            if (document.querySelectorAll('.complaint-card').length === 0) {
                location.reload();
            }
        }
    } catch (error) {
        console.error('Ошибка:', error);
        showNotification('Ошибка при удалении работы', 'error');
    }
}

function showNotification(message, type) {
    const notification = document.createElement('div');
    notification.className = `notification notification-${type}`;
    notification.innerHTML = `
        <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i>
        <span>${message}</span>
    `;
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
        notification.classList.add('fade-out');
        setTimeout(() => notification.remove(), 300);
    }, 3000);
}

// Закрытие модального окна при клике вне его
window.onclick = function(event) {
    const modal = document.getElementById('deleteWorkModal');
    if (event.target == modal) {
        modal.style.display = 'none';
    }
}

// Клавиша Escape
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        hideDeleteModal();
    }
});
</script>

<style>
.complaints-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.complaint-card {
    background: var(--white);
    border-radius: 10px;
    padding: 20px;
    box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    border-left: 4px solid;
}

.complaint-card.open {
    border-left-color: var(--error);
}

.complaint-card.closed {
    border-left-color: var(--success);
    opacity: 0.7;
}

.complaint-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
    padding-bottom: 15px;
    border-bottom: 1px solid var(--light-gray);
}

.complaint-meta {
    display: flex;
    align-items: center;
    gap: 15px;
}

.complaint-id {
    font-weight: 600;
    color: var(--primary);
}

.complaint-date {
    font-size: 13px;
    color: var(--gray);
}

.complaint-date i {
    margin-right: 5px;
}

.complaint-status {
    padding: 3px 8px;
    border-radius: 3px;
    font-size: 12px;
    font-weight: 500;
}

.status-open {
    background: var(--error);
    color: var(--white);
}

.status-closed {
    background: var(--success);
    color: var(--white);
}

.btn-close-complaint {
    background: var(--success);
    color: var(--white);
    border: none;
    padding: 5px 12px;
    border-radius: 3px;
    cursor: pointer;
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: background 0.3s;
}

.btn-close-complaint:hover {
    background: #218838;
}

.complaint-content {
    display: grid;
    grid-template-columns: 1fr 200px;
    gap: 20px;
}

.complaint-info p {
    margin-bottom: 8px;
    line-height: 1.5;
}

.complaint-info a {
    color: var(--primary);
    text-decoration: none;
}

.complaint-info a:hover {
    text-decoration: underline;
}

.complaint-work-preview {
    text-align: center;
}

.complaint-work-preview img {
    width: 100%;
    max-height: 150px;
    object-fit: cover;
    border-radius: 5px;
    margin-bottom: 10px;
}

.complaint-actions {
    display: flex;
    gap: 10px;
    justify-content: center;
}

/* Модальное окно */
.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
}

.modal-content {
    background: var(--white);
    margin: 50px auto;
    padding: 30px;
    max-width: 500px;
    border-radius: 10px;
    position: relative;
}

.close {
    position: absolute;
    right: 20px;
    top: 10px;
    font-size: 28px;
    cursor: pointer;
    color: var(--gray);
}

.close:hover {
    color: var(--dark);
}

.modal-actions {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
    margin-top: 20px;
}

#deleteReason {
    width: 100%;
    padding: 10px;
    border: 2px solid var(--light-gray);
    border-radius: 5px;
    font-family: inherit;
    resize: vertical;
}

/* Уведомления */
.notification {
    position: fixed;
    top: 20px;
    right: 20px;
    background: var(--white);
    color: var(--dark);
    padding: 15px 25px;
    border-radius: 5px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.2);
    display: flex;
    align-items: center;
    gap: 10px;
    z-index: 2000;
    animation: slideIn 0.3s;
}

.notification.success {
    border-left: 4px solid var(--success);
}

.notification.error {
    border-left: 4px solid var(--error);
}

@keyframes slideIn {
    from {
        transform: translateX(100%);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

.fade-out {
    animation: fadeOut 0.3s forwards;
}

@keyframes fadeOut {
    to {
        opacity: 0;
        transform: translateX(100%);
    }
}

@media (max-width: 768px) {
    .complaint-content {
        grid-template-columns: 1fr;
    }
    
    .complaint-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
    }
    
    .complaint-meta {
        flex-wrap: wrap;
    }
}
</style>

<%- include('../partials/footer') %>